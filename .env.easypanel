# =============================================================================
# .env.easypanel — Environment Variables for Easypanel Deployment
# =============================================================================
# Copy the REQUIRED variables into your Easypanel service's Environment tab.
# Optional variables can be added as needed for messaging platform integrations.
# =============================================================================

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED (MUST set in Easypanel — service will not start without these)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# NVIDIA API Key — LLM provider for the default model (deepseek-v4-flash)
# Get your free key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# API Server Key — Authentication key for the OpenAI-compatible API endpoint
# Generate a strong random string: openssl rand -hex 32
# This protects the API server from unauthorized access
API_SERVER_KEY=your-random-secret-key-here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RECOMMENDED (defaults are set, but you may want to customize)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# API Server Host — Bind address (0.0.0.0 exposes to network, localhost only local)
API_SERVER_HOST=0.0.0.0

# API Server Port — Default 8642
API_SERVER_PORT=8642

# Auto-start gateway on first boot
HERMES_GATEWAY_BOOTSTRAP_STATE=running

# Terminal backend (local = commands run inside the container)
TERMINAL_ENV=local

# Disable browser tool (no Chromium in slim image)
HERMES_BROWSER_DISABLED=1

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Messaging Platform Integrations
# Add only the platforms you want to use
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# TELEGRAM — Get token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=                        # REQUIRED — paste your bot token here
TELEGRAM_ALLOWED_USERS=                    # Comma-separated Telegram user IDs (leave blank = allow all)
TELEGRAM_HOME_CHANNEL=                     # Default chat ID for cron report delivery

# DISCORD — Create bot at https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=

# SLACK — Create app at https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Additional LLM Providers (for fallback or primary use)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OpenRouter — Many models through one API (https://openrouter.ai/keys)
# OPENROUTER_API_KEY=

# Google Gemini — (https://aistudio.google.com/app/apikey)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Web Search / Browser Tools
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Firecrawl — Web search, extract, crawl (https://firecrawl.dev/)
# FIRECRAWL_API_KEY=

# Exa — AI-native web search (https://exa.ai)
# EXA_API_KEY=

# Browserbase — Cloud browser execution (https://browserbase.com/)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
